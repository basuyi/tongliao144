# 服务器部署配置
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# SSH 服务器
SERVER_IP=你的服务器公网IP
SERVER_PASSWORD=你的服务器密码

# 阿里云 AccessKey (用于 ECS / OSS 操作)
# 获取地址: https://ram.console.aliyun.com/manage/ak
ALIBABA_CLOUD_ACCESS_KEY_ID=你的AccessKeyID
ALIBABA_CLOUD_ACCESS_KEY_SECRET=你的AccessKeySecret

# OSS 配置 (用于静态部署)
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=tongliao-144
