# 阿里云 AccessKey (用于 ECS / 轻量服务器 / OSS 操作)
# 获取地址: https://ram.console.aliyun.com/manage/ak
ALIBABA_CLOUD_ACCESS_KEY_ID=你的AccessKeyID
ALIBABA_CLOUD_ACCESS_KEY_SECRET=你的AccessKeySecret

# OSS 配置 (用于静态部署)
OSS_ACCESS_KEY_ID=你的AccessKeyID
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=tongliao-144

# 服务器配置 (用于 SSH 部署和服务器管理)
SERVER_IP=你的服务器公网IP
SERVER_PASSWORD=你的服务器密码
